{
  "name": "My Full-Stack App",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "backend",
  "workspaceFolder": "/workspaces",

  // "frontend" 서비스 컨테이너에서 "npm install"을 실행하도록 수정
  "postCreateCommand": {
    "frontend": "npm install"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint"
      ]
    }
  }
}