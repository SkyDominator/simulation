{
  "name": "My Full-Stack App",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "backend",

  // 컨테이너에 접속했을 때 기본 폴더를 프로젝트 루트로 변경
  "workspaceFolder": "/workspaces", 

  // npm install을 실행할 경로를 새 구조에 맞게 수정
  "postCreateCommand": "npm --prefix src/my-pwa-frontend install", 

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint"
      ]
    }
  }
}