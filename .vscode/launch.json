{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python Debugger: Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal"
    },

    {
      "name": "Backend: FastAPI (uvicorn + reload)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "main:app",
        "--reload",
        "--host",
        "0.0.0.0",
        "--port",
        "8000"
      ],
      "cwd": "/app/src/backend",
      "python": "/app/src/backend/backend-venv/bin/python",
      "env": {
        "PYTHONPATH": "/app/src/backend"
      },
      "console": "integratedTerminal",
      "subProcess": true,
      "justMyCode": true
    },

    {
      "name": "Frontend: Open in Host Browser (for OAuth)",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/src/my-pwa-frontend",
      // Use host browser so OAuth flows / cookies work normally
      "runtimeExecutable": "$BROWSER",
      "trace": false
    }
  ]
}