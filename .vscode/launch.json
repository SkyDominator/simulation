{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend: FastAPI (uvicorn + reload)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "main:app",
        "--reload",
        "--host",
        "0.0.0.0",
        "--port",
        "8000"
      ],
      "cwd": "/app/src/backend",
      "python": "/app/src/backend/backend-venv/bin/python",
      "env": {
        "PYTHONPATH": "/app/src/backend"
      },
      "console": "integratedTerminal",
      "subProcess": true,
      "justMyCode": true
    },
    {
    "name": "Launch Chrome (new profile)",
    "type": "pwa-chrome",
    "request": "launch",
    "url": "http://localhost:5173",
    "webRoot": "/app/src/my-pwa-frontend",
    "runtimeExecutable": "C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe",
    "runtimeArgs": [
        "--remote-debugging-port=9222",
        "--user-data-dir=${workspaceFolder}\\.vscode\\chrome-profile",
        "--disable-extensions",
        "--no-first-run"
    ],
    "trace": true
    }
  ],
  "compounds": [
    {
      "name": "Full Stack Debug",
      "configurations": [
        "Backend: FastAPI (uvicorn + reload)",
        "Frontend: Chrome (Vite + Breakpoints)"
      ]
    }
  ]
}