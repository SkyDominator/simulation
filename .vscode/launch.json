{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug: Backend",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["main:app", "--reload", "--host", "0.0.0.0", "--port", "8001"],
      "cwd": "${workspaceFolder}/src/backend",
      "python": "${workspaceFolder}/src/backend/venv/Scripts/python.exe",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src/backend"
      },
      "console": "integratedTerminal",
      "subProcess": true,
      "justMyCode": true
    },
    {
      "name": "Unit Test: Backend",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["tests/unit", "-v"],
      "cwd": "${workspaceFolder}/src/backend",
      "python": "${workspaceFolder}/src/backend/venv/Scripts/python.exe",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src/backend"
      },
      "console": "integratedTerminal",
      "subProcess": true,
      "justMyCode": true
    },
    {
      "name": "Security Test: Backend",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["tests/integration/api/test_security.py", "-v"],
      "cwd": "${workspaceFolder}/src/backend",
      "python": "${workspaceFolder}/src/backend/venv/Scripts/python.exe",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src/backend"
      },
      "console": "integratedTerminal",
      "subProcess": true,
      "justMyCode": true
    },
    {
      "name": "API Contract Test: Backend",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["tests/integration", "-v"],
      "cwd": "${workspaceFolder}/src/backend",
      "python": "${workspaceFolder}/src/backend/venv/Scripts/python.exe",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src/backend"
      },
      "console": "integratedTerminal",
      "subProcess": true,
      "justMyCode": true
    },
    {
      "name": "Debug: Frontend",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/src/frontend",
      "userDataDir": "${workspaceFolder}/.vscode/chrome-debug-profile",
      "sourceMaps": true,
      "trace": true,
    "runtimeArgs": [
      "--remote-debugging-port=9222",
      "--user-data-dir=${workspaceFolder}/.vscode/chrome-debug-profile",
      "--no-first-run",
      "--no-default-browser-check",
      "--disable-extensions"
    ],
    "port": 9222
    },
    {
        "name": "Smoke Test: Frontend",
        "type": "node",
        "request": "launch",
        "program": "${workspaceFolder}/src/frontend/node_modules/vitest/vitest.mjs",
        "args": ["run", "--reporter=verbose", "--coverage"],
        "cwd": "${workspaceFolder}/src/frontend",
        "console": "integratedTerminal",
        "skipFiles": ["<node_internals>/**"],
        "env": {
        "NODE_ENV": "test"
        }
    },
    {
        "name": "E2E Test: Frontend",
        "type": "node",
        "request": "launch",
        "program": "${workspaceFolder}/src/frontend/node_modules/vitest/vitest.mjs",
        "args": ["run", "e2e", "--reporter=verbose", "--coverage"],
        "cwd": "${workspaceFolder}/src/frontend",
        "console": "integratedTerminal",
        "skipFiles": ["<node_internals>/**"],
        "env": {
        "NODE_ENV": "test"
        }
    },
    {
        "name": "Security Test: Frontend",
        "type": "node",
        "request": "launch",
        "program": "${workspaceFolder}/src/frontend/node_modules/vitest/vitest.mjs",
        "args": ["run", "src/test/security", "--reporter=verbose", "--coverage"],
        "cwd": "${workspaceFolder}/src/frontend",
        "console": "integratedTerminal",
        "skipFiles": ["<node_internals>/**"],
        "env": {
        "NODE_ENV": "test"
        }
    },
    {
      "name": "Debug: Python Single File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ],
  "compounds": [
    {
      "name": "Debug: Full Stack",
      "configurations": [
        "Debug: Backend",
        "Debug: Frontend"
      ]
    },
    {
      "name": "Security Tests (Debug)",
      "configurations": [
        "Security Test: Backend",
        "Security Test: Frontend"
      ]
    },

  ]
}
