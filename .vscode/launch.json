{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend: FastAPI (uvicorn + reload)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "main:app",
        "--reload",
        "--host",
        "0.0.0.0",
        "--port",
        "8000"
      ],
      "cwd": "/app/src/backend",
      "python": "/app/src/backend/backend-venv/bin/python",
      "env": {
        "PYTHONPATH": "/app/src/backend"
      },
      "console": "integratedTerminal",
      "subProcess": true,
      "justMyCode": true
    },
    {
      "name": "Frontend: Chrome (Vite + Breakpoints)",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/src/my-pwa-frontend",
      "runtimeExecutable": "$BROWSER",
      "sourceMaps": true,
      "sourceMapPathOverrides": {
        "/app/src/my-pwa-frontend/*": "${webRoot}/*"
      },
      "trace": false
    }
  ],
  "compounds": [
    {
      "name": "Full Stack Debug",
      "configurations": [
        "Backend: FastAPI (uvicorn + reload)",
        "Frontend: Chrome (Vite + Breakpoints)"
      ]
    }
  ]
}