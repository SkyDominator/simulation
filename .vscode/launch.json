{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python Debugger: Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal"
    },

    {
    "name": "Backend: FastAPI (uvicorn + reload)",
    "type": "debugpy",
    "request": "launch",
    "module": "uvicorn",
    "args": [
        "main:app",
        "--reload",
        "--host", "127.0.0.1",
        "--port", "8000"
    ],
    "cwd": "${workspaceFolder}/src/backend",
    "python": "${workspaceFolder}/src/backend/backend-venv/Scripts/python.exe",
    "env": {
        "PYTHONPATH": "${workspaceFolder}/src/backend"
    },
    "console": "integratedTerminal",
    "subProcess": true,        // important: debug into uvicorn’s reloaded worker
    "justMyCode": true
    },
    {
    "name": "Launch Chrome (new profile)",
    "type": "pwa-chrome",
    "request": "launch",
    "url": "http://localhost:5173",
    "webRoot": "${workspaceFolder}/src/my-pwa-frontend",
    "runtimeExecutable": "C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe",
    "runtimeArgs": [
        "--remote-debugging-port=9222",
        "--user-data-dir=${workspaceFolder}\\.vscode\\chrome-profile",
        "--disable-extensions",
        "--no-first-run"
    ],
    "trace": true
    }

  ],
}