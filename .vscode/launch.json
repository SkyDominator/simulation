{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend (launch)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["main:app", "--reload", "--host", "0.0.0.0", "--port", "8001"],
      "cwd": "${workspaceFolder}/src/backend",
      "python": "${workspaceFolder}/src/backend/venv/Scripts/python.exe",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src/backend"
      },
      "console": "integratedTerminal",
      "subProcess": true,
      "justMyCode": true
    },
    {
      "name": "Unit test: backend (debug)",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["tests/unit", "-v", ">", "test_unit_results.md"],
      "cwd": "${workspaceFolder}/src/backend",
      "python": "${workspaceFolder}/src/backend/venv/Scripts/python.exe",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src/backend"
      },
      "console": "integratedTerminal",
      "subProcess": true,
      "justMyCode": true
    },
    {
      "name": "Unit test: backend",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["tests/unit", "-v"],
      "cwd": "${workspaceFolder}/src/backend",
      "python": "${workspaceFolder}/src/backend/venv/Scripts/python.exe",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src/backend"
      },
      "console": "integratedTerminal",
      "subProcess": true,
      "justMyCode": true
    },
    {
      "name": "API contract test: backend (debug)",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["tests/integration", "-v", ">", "test_integration_results.md"],
      "cwd": "${workspaceFolder}/src/backend",
      "python": "${workspaceFolder}/src/backend/venv/Scripts/python.exe",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src/backend"
      },
      "console": "integratedTerminal",
      "subProcess": true,
      "justMyCode": true
    },
    {
      "name": "API contract test: backend",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["tests/integration", "-v"],
      "cwd": "${workspaceFolder}/src/backend",
      "python": "${workspaceFolder}/src/backend/venv/Scripts/python.exe",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src/backend"
      },
      "console": "integratedTerminal",
      "subProcess": true,
      "justMyCode": true
    },
    {
      "name": "Frontend: Chrome (Vite + Breakpoints)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/src/frontend",
      "userDataDir": "${workspaceFolder}/.vscode/chrome-debug-profile",
      "sourceMaps": true,
      "trace": true,
    "runtimeArgs": [
      "--remote-debugging-port=9222",
      "--user-data-dir=${workspaceFolder}/.vscode/chrome-debug-profile",
      "--no-first-run",
      "--no-default-browser-check",
      "--disable-extensions"
    ],
    "port": 9222
    },
    {
        "name": "Frontend Smoke Tests (debug)",
        "type": "node",
        "request": "launch",
        "program": "${workspaceFolder}/src/frontend/node_modules/vitest/vitest.mjs",
        "args": ["run", "--reporter=json", "--reporter=verbose", "--coverage", "--outputFile=test_smoke_results.json"],
        "cwd": "${workspaceFolder}/src/frontend",
        "console": "integratedTerminal",
        "skipFiles": ["<node_internals>/**"],
        "env": {
        "NODE_ENV": "test"
        }
    },
    {
        "name": "Frontend Smoke Tests",
        "type": "node",
        "request": "launch",
        "program": "${workspaceFolder}/src/frontend/node_modules/vitest/vitest.mjs",
        "args": ["run", "--reporter=verbose", "--coverage"],
        "cwd": "${workspaceFolder}/src/frontend",
        "console": "integratedTerminal",
        "skipFiles": ["<node_internals>/**"],
        "env": {
        "NODE_ENV": "test"
        }
    },
    {
      "name": "Python: Single File Debug",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ],
  "compounds": [
    {
      "name": "Full Stack Debug",
      "configurations": [
        "Backend (launch)",
        "Frontend: Chrome (Vite + Breakpoints)"
      ]
    }
  ]
}
