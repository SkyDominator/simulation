{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug: Backend",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["main:app", "--reload", "--host", "0.0.0.0", "--port", "8001"],
      "cwd": "${workspaceFolder}/src/backend",
      "python": "${workspaceFolder}/src/backend/venv/Scripts/python.exe",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src/backend"
      },
      "console": "integratedTerminal",
      "subProcess": true,
      "justMyCode": true
    },
        {
      "name": "Debug: Frontend",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/src/frontend",
      "userDataDir": "${workspaceFolder}/.vscode/chrome-debug-profile",
      "sourceMaps": true,
      "trace": true,
      "runtimeArgs": [
        "--remote-debugging-port=9222",
        "--user-data-dir=${workspaceFolder}/.vscode/chrome-debug-profile",
        "--no-first-run",
        "--no-default-browser-check",
        "--disable-extensions"
      ],
      "port": 9222
    },
    {
      "name": "Unit Test: Backend",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["tests/unit", "--ignore=tests/unit/security/test_cryptography.py", "-v"],
      "cwd": "${workspaceFolder}/src/backend",
      "python": "${workspaceFolder}/src/backend/venv/Scripts/python.exe",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src/backend"
      },
      "console": "integratedTerminal",
      "subProcess": true,
      "justMyCode": true
    },
    {
      "name": "Unit Test: Frontend",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/src/frontend/node_modules/vitest/vitest.mjs",
      "args": ["run", "src/test/pages", "--reporter=verbose"],
      "cwd": "${workspaceFolder}/src/frontend",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "env": {
        "NODE_ENV": "test"
      }
    },
    {
      "name": "Smoke Test (Basic Setup): Frontend",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/src/frontend/node_modules/vitest/vitest.mjs",
      "args": ["run", "src/test/smoke.test.tsx", "--reporter=verbose"],
      "cwd": "${workspaceFolder}/src/frontend",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "env": {
        "NODE_ENV": "test"
      }
    },
    {
      "name": "Component Test: Frontend",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/src/frontend/node_modules/vitest/vitest.mjs",
      "args": ["run", "src/test/components", "--reporter=verbose"],
      "cwd": "${workspaceFolder}/src/frontend",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "env": {
        "NODE_ENV": "test"
      }
    },
    {
      "name": "Integration Test: Backend",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["tests/integration", "--ignore=tests/integration/api/test_security_e2e.py", "-v"],
      "cwd": "${workspaceFolder}/src/backend",
      "python": "${workspaceFolder}/src/backend/venv/Scripts/python.exe",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src/backend"
      },
      "console": "integratedTerminal",
      "subProcess": true,
      "justMyCode": true
    },
    {
      "name": "Integration Test: Frontend",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/src/frontend/node_modules/vitest/vitest.mjs",
      "args": ["run", "src/test/integration", "--reporter=verbose"],
      "cwd": "${workspaceFolder}/src/frontend",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "env": {
        "NODE_ENV": "test"
      }
    },
    {
      "name": "Security Test: Backend",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["tests/integration/api/test_security_e2e.py", "tests/unit/security/test_cryptography.py", "-v"],
      "cwd": "${workspaceFolder}/src/backend",
      "python": "${workspaceFolder}/src/backend/venv/Scripts/python.exe",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src/backend"
      },
      "console": "integratedTerminal",
      "subProcess": true,
      "justMyCode": true
    },
    {
      "name": "Security Test: Frontend",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/src/frontend/node_modules/vitest/vitest.mjs",
      "args": ["run", "src/test/security", "--reporter=verbose"],
      "cwd": "${workspaceFolder}/src/frontend",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "env": {
        "NODE_ENV": "test"
      }
    },
        {
      "name": "E2E Test: Frontend",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/src/frontend/node_modules/@playwright/test/cli.js",
      "args": ["test", "--reporter=list", "--project=Mobile Chrome"],
      "cwd": "${workspaceFolder}/src/frontend",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "env": {
        "NODE_ENV": "test"
      }
    },
    // {
    //   "name": "Unit Test (Watch): Frontend",
    //   "type": "node",
    //   "request": "launch",
    //   "program": "${workspaceFolder}/src/frontend/node_modules/vitest/vitest.mjs",
    //   "args": ["src/**/*.{test,spec}.{ts,tsx}", "--exclude", "**/*.e2e.{test,spec}.{ts,tsx}", "--exclude", "**/*.security.{test,spec}.{ts,tsx}", "--reporter=verbose"],
    //   "cwd": "${workspaceFolder}/src/frontend",
    //   "console": "integratedTerminal",
    //   "skipFiles": ["<node_internals>/**"],
    //   "env": {
    //     "NODE_ENV": "test"
    //   }
    // },
    
    // {
    //   "name": "E2E Test (Debug): Frontend",
    //   "type": "node",
    //   "request": "launch",
    //   "program": "${workspaceFolder}/src/frontend/node_modules/.bin/playwright",
    //   "args": ["test", "--debug", "--project=chromium"],
    //   "cwd": "${workspaceFolder}/src/frontend",
    //   "console": "integratedTerminal",
    //   "skipFiles": ["<node_internals>/**"],
    //   "env": {
    //     "NODE_ENV": "test",
    //     "PWDEBUG": "1"
    //   }
    // },

    {
      "name": "Debug: Python Single File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ],
  "compounds": [
    {
      "name": "Debug: Full Stack",
      "configurations": [
        "Debug: Backend",
        "Debug: Frontend"
      ]
    },
    {
      "name": "All Unit Tests",
      "configurations": [
        "Unit Test: Backend",
        "Unit Test: Frontend"
      ]
    },
    {
      "name": "All Integration Tests",
      "configurations": [
        "Integration Test: Backend",
        "Integration Test: Frontend"
      ]
    },
    {
      "name": "All Security Tests",
      "configurations": [
        "Security Test: Backend",
        "Security Test: Frontend"
      ]
    },
    {
      "name": "All Frontend Tests (Excl. E2E)",
      "configurations": [
        "Unit Test: Frontend",
        "Smoke Test (Basic Setup): Frontend",
        "Component Test: Frontend",
        "Integration Test: Frontend",
        "Security Test: Frontend"
      ]
    },
    {
      "name": "All Backend Tests",
      "configurations": [
        "Unit Test: Backend",
        "Integration Test: Backend",
        "Security Test: Backend"
      ]
    },
    {
      "name": "All Tests (Excl. E2E)",
      "configurations": [
        "Unit Test: Backend",
        "Integration Test: Backend",
        "Security Test: Backend",
        "Unit Test: Frontend",
        "Smoke Test (Basic Setup): Frontend",
        "Component Test: Frontend",
        "Integration Test: Frontend",
        "Security Test: Frontend",
      ]
    }
  ]
}
