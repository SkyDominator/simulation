# Supabase Configuration
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SECRET_KEY=your-service-role-key
# SUPABASE_PUBLISHABLE_KEY=your-anon-public-key  # Alternative to secret key

# OTP Configuration
OTP_SECRET_KEY=your-otp-encryption-key
OTP_VALIDITY_MINUTES=5
OTP_RESEND_LIMIT_PER_15MIN=3
OTP_RESEND_LIMIT_PER_DAY=10
otp_max_verification_attempts=6

# SMS Provider Configuration (choose one)

# Solapi (Korean SMS service) - Primary
SOLAPI_API_KEY=your-solapi-api-key
SOLAPI_API_SECRET=your-solapi-api-secret
SOLAPI_SENDER_NUMBER=your-sender-phone-number

# NHN Cloud (Korean SMS service) - Legacy
NHN_CLOUD_APPKEY=your-nhn-appkey
NHN_CLOUD_SECRET_KEY=your-nhn-secret
NHN_CLOUD_SENDER_NUMBER=your-nhn-sender-number

# Health Notification Service Configuration
HEALTH_MONITORING_ENABLED=true
HEALTH_CHECK_INTERVAL=60.0
HEALTH_CHECK_TIMEOUT=10.0
HEALTH_SLOW_THRESHOLD_MS=3000.0

# Telegram Notifications (Recommended - Easy to set up)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_CHAT_ID=123456789

# KakaoTalk Notifications (Korea-specific)
KAKAO_APP_KEY=your-kakao-app-key
KAKAO_RECIPIENT_ID=recipient-uuid

# iOS Push Notifications (Advanced setup required)
IOS_APNS_KEY_ID=ABC123DEF4
IOS_TEAM_ID=TEAM123456
IOS_BUNDLE_ID=com.example.simulation
IOS_APNS_KEY_PATH=/path/to/AuthKey_ABC123DEF4.p8
IOS_DEVICE_TOKEN=device-token-from-ios-app
IOS_USE_SANDBOX=false