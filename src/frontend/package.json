{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:run": "vitest run",
    "test:run:save": "vitest run > test-results/unit-test-output.log 2>&1",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:journeys": "playwright test --grep \"E2E-JOURNEY\"",
    "test:e2e:mobile": "playwright test --max-failures=5 --project=\"Mobile Chrome\"",
    "test:e2e:mobile:auth": "playwright test e2e/specs/auth-session.spec.ts --max-failures=5 --project=\"Mobile Chrome\"",
    "test:e2e:desktop": "playwright test --max-failures=5 --project=\"Google Chrome\"",
    "test:e2e:save:mobile": "playwright test --max-failures=5 --project=\"Mobile Chrome\" --reporter=list 2>&1 | node -e \"const s=require('fs').readFileSync(0,'utf8'); process.stdout.write(s.replace(/\\x1B\\[[0-9;]*[a-zA-Z]|\\[[0-9;]*m/g,''));\" > test-results/e2e-output-mobile.log",
    "test:e2e:save:desktop": "playwright test --max-failures=5 --project=\"Google Chrome\" --reporter=list 2>&1 | node -e \"const s=require('fs').readFileSync(0,'utf8'); process.stdout.write(s.replace(/\\x1B\\[[0-9;]*[a-zA-Z]|\\[[0-9;]*m/g,''));\" > test-results/e2e-output-desktop.log"
  },
  "dependencies": {
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^5.14.0",
    "@mui/material": "^5.14.0",
    "@supabase/supabase-js": "^2.51.0",
    "@tailwindcss/vite": "^4.1.11",
    "@types/dompurify": "^3.0.5",
    "dompurify": "^3.2.7",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@playwright/test": "^1.55.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.4.19",
    "cross-env": "^10.1.0",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "eslint-plugin-security": "^2.1.1",
    "globals": "^16.3.0",
    "jsdom": "^27.0.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^5.4.10",
    "vite-plugin-pwa": "^0.20.0",
    "vitest": "^3.2.4"
  }
}
